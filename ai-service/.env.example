# 通义千问 API Key（从 https://dashscope.console.aliyun.com/ 获取）
# 切勿提交真实 Key 到 Git
DASHSCOPE_API_KEY=your-api-key-here

# 模型名称，默认 qwen-turbo（固定 RAG 流水线使用）
TONGYI_MODEL=qwen-turbo

# 对话模式：agent | rag
CHAT_MODE=agent

# Agent 编排（Function Calling，建议 qwen-plus）
AGENT_MODEL=qwen-plus
AGENT_MAX_STEPS=6

# 服务端口
AI_SERVICE_PORT=8090

# MySQL（与 Java 微服务共用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=demo1
MYSQL_DATABASE=myit_world

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# 给 LLM 的滑动窗口（消息条数）
HISTORY_WINDOW=20

# Gateway（拉取博客正文）
GATEWAY_BASE_URL=http://127.0.0.1:8080

# blog-service 内网直连（入库后台任务用，避免二次过 Gateway 时 JWT 失效）
BLOG_SERVICE_BASE_URL=http://127.0.0.1:8084

# Qdrant 向量库
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=blog_chunks

# Embedding（Chat 仍用上方百炼 Key；Embedding 走 Ollama）
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://10.8.7.58:11434
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIMENSION=1024
OLLAMA_TIMEOUT_SECONDS=120

# 文档切分
CHUNK_SIZE=800
CHUNK_OVERLAP=128
SEARCH_TOP_K=5
